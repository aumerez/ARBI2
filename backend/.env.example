# Async SQLAlchemy database URL.
# Local dev (default): SQLite, no external services required.
DATABASE_URL=sqlite+aiosqlite:///./arbi.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://arbi:arbi@localhost:5432/arbi

# Create tables on startup (dev). Set false and use Alembic in production.
AUTO_CREATE_TABLES=true
